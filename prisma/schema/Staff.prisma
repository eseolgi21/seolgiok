// ===== 출퇴근 =====

enum AttendanceType {
  CLOCK_IN
  CLOCK_OUT
}

model AttendanceLog {
  id             String         @id @default(cuid())
  userId         String
  user           User           @relation("StaffAttendance", fields: [userId], references: [id], onDelete: Cascade)
  type           AttendanceType
  clockedAt      DateTime       @default(now())
  note           String?
  latitude       Float?
  longitude      Float?
  distanceMeters Float?
  storeId        String?
  store          Store?         @relation(fields: [storeId], references: [id], onDelete: SetNull)
  createdAt      DateTime       @default(now())

  @@index([userId, clockedAt])
  @@index([clockedAt])
  @@index([storeId, clockedAt])
}

// ===== 매장 (멀티매장 지오펜싱 기준점) =====

model Store {
  id           String   @id @default(cuid())
  name         String
  address      String?
  latitude     Float
  longitude    Float
  radiusMeters Int      @default(100)
  timezone     String   @default("Asia/Seoul")
  isActive     Boolean  @default(true)
  updatedAt    DateTime @updatedAt
  updatedBy    String?
  updater      User?    @relation("StoreUpdater", fields: [updatedBy], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())

  members        UserInfo[]
  attendanceLogs AttendanceLog[]

  handoverItems     HandoverItem[]
  handoverSlots     HandoverShiftSlot[]
  handoverChecks    HandoverCheck[]
  handoverComments  HandoverComment[]
  handoverApprovals HandoverApproval[]

  @@unique([name])
  @@index([isActive])
}

// ===== 인수인계 체크리스트 =====

model HandoverItem {
  id        String          @id @default(cuid())
  storeId   String
  store     Store           @relation(fields: [storeId], references: [id], onDelete: Restrict)
  label     String
  category  String          @default("HALL")
  order     Int             @default(0)
  isActive  Boolean         @default(true)
  checks    HandoverCheck[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([isActive, order])
  @@index([category, isActive, order])
  @@index([storeId, isActive, order])
}

model HandoverShiftSlot {
  id        String             @id @default(cuid())
  storeId   String
  store     Store              @relation(fields: [storeId], references: [id], onDelete: Restrict)
  label     String
  category  String             @default("HALL")
  order     Int                @default(0)
  isActive  Boolean            @default(true)
  checks    HandoverCheck[]
  comments  HandoverComment[]
  approvals HandoverApproval[]
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([isActive, category, order])
  @@index([storeId, isActive, category, order])
}

model HandoverCheck {
  id          String            @id @default(cuid())
  storeId     String
  store       Store             @relation(fields: [storeId], references: [id], onDelete: Restrict)
  itemId      String
  item        HandoverItem      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  shiftDate   DateTime          @db.Date
  shiftSlotId String
  shiftSlot   HandoverShiftSlot @relation(fields: [shiftSlotId], references: [id], onDelete: Restrict)
  checkedBy   String
  checkedUser User              @relation("StaffHandoverCheck", fields: [checkedBy], references: [id], onDelete: Cascade)
  checkedAt   DateTime          @default(now())

  @@unique([storeId, itemId, shiftDate, shiftSlotId, checkedBy])
  @@index([storeId, shiftDate, shiftSlotId])
  @@index([shiftDate, shiftSlotId])
  @@index([checkedBy])
}

model HandoverComment {
  id          String            @id @default(cuid())
  storeId     String
  store       Store             @relation(fields: [storeId], references: [id], onDelete: Restrict)
  shiftDate   DateTime          @db.Date
  shiftSlotId String
  shiftSlot   HandoverShiftSlot @relation(fields: [shiftSlotId], references: [id], onDelete: Restrict)
  category    String
  authorId    String
  author      User              @relation("StaffHandoverComment", fields: [authorId], references: [id], onDelete: Cascade)
  content     String
  imageUrl    String?
  createdAt   DateTime          @default(now())

  @@index([shiftDate, shiftSlotId, category])
  @@index([storeId, shiftDate, shiftSlotId, category])
  @@index([authorId])
}

model HandoverApproval {
  id          String            @id @default(cuid())
  storeId     String
  store       Store             @relation(fields: [storeId], references: [id], onDelete: Restrict)
  shiftDate   DateTime          @db.Date
  shiftSlotId String
  shiftSlot   HandoverShiftSlot @relation(fields: [shiftSlotId], references: [id], onDelete: Restrict)
  category    String
  status      String            @default("PENDING")
  submittedBy String
  submitter   User              @relation("HandoverApprovalSubmitter", fields: [submittedBy], references: [id], onDelete: Restrict)
  submittedAt DateTime          @default(now())
  confirmedBy String?
  confirmer   User?             @relation("HandoverApprovalConfirmer", fields: [confirmedBy], references: [id], onDelete: SetNull)
  confirmedAt DateTime?
  note        String?

  @@unique([storeId, shiftDate, shiftSlotId, category])
  @@index([storeId, shiftDate, shiftSlotId])
  @@index([shiftDate, shiftSlotId])
}

// ===== 이달의 우수사원 투표 =====

model EmployeeVote {
  id        String   @id @default(cuid())
  voterId   String
  voter     User     @relation("VoteCaster", fields: [voterId], references: [id], onDelete: Cascade)
  targetId  String
  target    User     @relation("VoteReceiver", fields: [targetId], references: [id], onDelete: Cascade)
  voteDate  DateTime @db.Date
  voteYear  Int
  voteMonth Int
  createdAt DateTime @default(now())

  @@unique([voterId, voteDate])
  @@index([voteYear, voteMonth, targetId])
  @@index([voterId, voteDate])
}

// ===== 급여명세서 =====

model Payslip {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation("StaffPayslip", fields: [userId], references: [id], onDelete: Cascade)
  year       Int
  month      Int
  fileName   String
  fileSize   Int
  fileData   Bytes
  uploadedAt DateTime @default(now())
  uploadedBy String
  uploader   User     @relation("PayslipUploader", fields: [uploadedBy], references: [id], onDelete: Restrict)

  @@unique([userId, year, month])
  @@index([userId, year, month])
  @@index([year, month])
}
